{
  "getTicket": {
    "schema": {
      "method": "GET",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "getConversations": {
    "schema": {
      "method": "GET",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>/conversations",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "makeWebhook": {
    "schema": {
      "method": "POST",
      "host": "<%= iparam.make_webhook_host %>",
      "path": "<%= iparam.make_webhook_path %>",
      "headers": {
        "Content-Type": "application/json"
      }
    }
  },
  "getCannedResponses": {
    "schema": {
      "method": "GET",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/canned_responses?page=<%= context.page %>",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  }
}
